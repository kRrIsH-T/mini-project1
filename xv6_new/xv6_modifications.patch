-    // to avoid a possible race between an interrupt
-    // and wfi.
+    // Avoid deadlock by ensuring that devices can interrupt.
     intr_on();
+
+#ifdef SCHEDULER_FCFS
+    // First Come First Serve Scheduler
+    struct proc *earliest_proc = 0;
+    uint64 earliest_time = ~0ULL;  // Initialize to maximum value
+    
+    static int debug_counter = 0;
+    if((debug_counter++ % 1000000) == 0) printf("FCFS Scheduler Active\n");
+    
     intr_off();
+    
+    // Find the runnable process with earliest creation time
+    for(p = proc; p < &proc[NPROC]; p++) {
+      acquire(&p->lock);
+      if(p->state == RUNNABLE && p->creation_time < earliest_time) {
+        if(earliest_proc != 0) {
+          release(&earliest_proc->lock);
+        }
+        earliest_proc = p;
+        earliest_time = p->creation_time;
+      } else {
