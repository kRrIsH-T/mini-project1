+      }
+    }
+    
+    // Now run the chosen process (if any)
+    if(earliest_proc != 0) {
+      // Double-check it's still runnable (state could have changed)
+      if(earliest_proc->state == RUNNABLE) {
+        // Switch to chosen process
+        earliest_proc->state = RUNNING;
+        c->proc = earliest_proc;
+        swtch(&c->context, &earliest_proc->context);
+        
+        // Process is done running for now.
+        c->proc = 0;
+      }
+      release(&earliest_proc->lock);
+    } else {
+      // No runnable processes found, yield CPU briefly
+      intr_on();
+      asm volatile("wfi"); // Wait for interrupt
+      intr_off();
+    }
 
+#elif defined(SCHEDULER_CFS)
+    // Completely Fair Scheduler
+    struct proc *min_vruntime_proc = 0;
+    uint64 min_vruntime = 0;
+    int runnable_count = count_runnable_processes();
+    
+    static int debug_counter = 0;
+    if((debug_counter++ % 1000000) == 0) printf("CFS Scheduler Active\n");
+    
+    intr_off();
+    
+    // Find the runnable process with minimum vruntime
+    for(p = proc; p < &proc[NPROC]; p++) {
+      acquire(&p->lock);
+      if(p->state == RUNNABLE) {
+        if(min_vruntime_proc == 0 || p->vruntime < min_vruntime) {
+          if(min_vruntime_proc != 0) {
+            release(&min_vruntime_proc->lock);
+          }
+          min_vruntime_proc = p;
