+uint64
+sys_nice(void)
+{
+  int n;
+  argint(0, &n);
+  
+  // Clamp nice value to valid range
+  if(n < -20) n = -20;
+  if(n > 19) n = 19;
+  
+  struct proc *p = myproc();
+  acquire(&p->lock);
+  p->nice = n;
+  p->weight = calculate_weight(n);
+  release(&p->lock);
+  
+  return 0;
+}
