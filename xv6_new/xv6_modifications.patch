+// Calculate scheduling weight based on nice value
+// Approximation: weight = 1024 / (1.25 ^ nice)
+int
+calculate_weight(int nice)
+{
+  if (nice == 0) return 1024;
+  if (nice == -20) return 88761;
+  if (nice == 19) return 15;
+  
+  // Simplified approximation for other values
+  int weight = 1024;
+  if (nice > 0) {
+    for (int i = 0; i < nice; i++) {
+      weight = (weight * 4) / 5;  // Divide by 1.25
+    }
+  } else {
+    for (int i = 0; i < -nice; i++) {
+      weight = (weight * 5) / 4;  // Multiply by 1.25
+    }
+  }
+  return weight > 0 ? weight : 1;
+}
+
+// Count runnable processes for CFS time slice calculation
+int
+count_runnable_processes(void)
+{
+  struct proc *p;
+  int count = 0;
+  
+  for(p = proc; p < &proc[NPROC]; p++) {
+    acquire(&p->lock);
+    if(p->state == RUNNABLE) {
+      count++;
+    }
+    release(&p->lock);
+  }
+  return count > 0 ? count : 1;
+}
+
+// Calculate time slice for CFS
+uint64
+calculate_time_slice(int runnable_count)
+{
+  uint64 target_latency = 48;  // Target latency in ticks
+  uint64 time_slice = target_latency / runnable_count;
+  return time_slice < 3 ? 3 : time_slice;  // Minimum 3 ticks
+}
